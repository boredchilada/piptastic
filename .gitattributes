# Auto-detect text files and normalize to LF on commit, native on checkout
* text=auto

# Force LF for files that production (Linux) actually runs
*.sh        text eol=lf
*.py        text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
.gitignore  text eol=lf

# Binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
